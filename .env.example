# Copy to `.env` and adjust. Real environment variables override these.
# Loaded at startup by dotenvy; the file is optional.

# Listen port
PORT=3000

# Storage: `true` switches responses to signed-URL mode (default false = inline base64)
STORAGE_ENABLED=false
# OpenDAL backend: fs | s3 | gcs | azblob | memory | ...
OPENDAL_SCHEME=fs
# Passthrough OpenDAL config (prefix OPENDAL_, e.g. root/bucket/region)
OPENDAL_ROOT=./storage
# OPENDAL_BUCKET=my-bucket

# Signed-URL settings (fs backend)
PUBLIC_BASE_URL=http://localhost:3000
# HMAC key for fs signed URLs; random per boot if unset (set this in production)
# SIGNING_KEY=change-me
URL_TTL_SECS=3600

# Limits
MAX_BODY_BYTES=8388608   # 8 MiB outer request cap
MAX_HTML_BYTES=2097152   # 2 MiB /v1/pdf html cap -> 413
MAX_IMAGE_PAGES=10       # /v1/images page cap
RATE_LIMIT_PER_MIN=60    # per-IP request cap
